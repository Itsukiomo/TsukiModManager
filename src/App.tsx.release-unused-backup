function pakDisplayName(fileName: string) {
  return fileName
    .replace(/\.disabled$/i, "")
    .replace(/\.(pak|ucas|utoc)$/i, "")
    .replace(/[_-]+P$/i, "")
    .replace(/[_-]+/g, " ")
    .trim() || fileName;
}


