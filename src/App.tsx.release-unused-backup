              <div className={`managed-row ${install.enabled ? "" : "disabled"}`} key={install.id}>
                <div>
                  <strong>{install.displayName}</strong>
                  <p>
                    {install.source} #{install.sourceModId ?? "?"} · {install.fileCount} files · {install.nonPakFileCount} non-PAK
