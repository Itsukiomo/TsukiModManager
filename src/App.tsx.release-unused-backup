    setBusyId(install.id);
    invoke<string>("set_managed_install_enabled", { receiptId: install.id, enabled })
      .then((message) => {
        setStatus(message);
        refresh();
      })
      .catch((error) => setStatus(error instanceof Error ? error.message : String(error)))
      .finally(() => setBusyId(null));
  };

